# dependencies & build output
node_modules/
app/node_modules/
app/release/
app/dist/

# local runtime data (created at runtime, never committed)
config.json
metrics.json
*.log

# licensing server secrets & data (NEVER commit the private key)
server/.keys/
server/.data/

# deploy credentials (hosting host/login/password) — local only
scripts/deploy.env

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.tmp
scripts/server-update.env

# PHP backend secrets (private key, local test artifacts) — never commit
server-php/.keys/
