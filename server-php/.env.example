# Copy to server-php/.env on the server and fill in. NEVER commit .env (gitignored).

# ---- storage (MySQL on the hosting) ----
DB_DSN=mysql:host=localhost;dbname=YOUR_DB;charset=utf8mb4
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD

# ---- license signing (EC P-256 private key) ----
# Either run `php keygen.php` once (writes .keys/ec-private.pem) and leave this unset,
# or paste the private key PEM here (single line with \n) via LICENSE_PRIVATE_KEY.
# LICENSE_PRIVATE_KEY=

# ---- sign-in code emails ----
# DRIFTLY_MAILER options:
#   php-mail      → free + self-contained: sends as MAIL_FROM_EMAIL through the host's
#                   MTA (PHP mail()). Enable DKIM for the domain in the panel and keep
#                   the host IP in SPF so codes don't land in spam. This is our default.
#   unisender-go  → RU ESP (HTTP API). Best deliverability but the free_tier only sends
#                   to verified domains (external recipient → code 903); needs a paid plan.
#   console       → dev only; returns the code in the API response (no real email).
DRIFTLY_MAILER=php-mail
MAIL_FROM_EMAIL=support@driftly.site
MAIL_FROM_NAME=Driftly
# -- Unisender Go (only if DRIFTLY_MAILER=unisender-go) --
UNISENDER_GO_API_KEY=YOUR_UNISENDER_KEY
# Account is node-pinned (go1/go2); wrong node → code 114 "User not found". Ours is go2:
UNISENDER_GO_API_URL=https://go2.unisender.ru/ru/transactional/api/v1

# ---- payments (T-Bank / Т-Касса) ----
DRIFTLY_PROVIDER=tbank
TBANK_TERMINAL_KEY=YOUR_TERMINAL_KEY
TBANK_PASSWORD=YOUR_TERMINAL_PASSWORD
# TBANK_API=https://securepay.tinkoff.ru/v2
TBANK_NOTIFICATION_URL=https://api.driftly.site/v1/webhooks/tbank
TBANK_SUCCESS_URL=https://driftly.site/app/?paid=1
TBANK_FAIL_URL=https://driftly.site/app/?paid=0

# ---- misc ----
MAX_DEVICES=2
