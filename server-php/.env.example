# Copy to server-php/.env on the server and fill in. NEVER commit .env (gitignored).

# ---- storage (MySQL on the hosting) ----
DB_DSN=mysql:host=localhost;dbname=YOUR_DB;charset=utf8mb4
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD

# ---- license signing (EC P-256 private key) ----
# Either run `php keygen.php` once (writes .keys/ec-private.pem) and leave this unset,
# or paste the private key PEM here (single line with \n) via LICENSE_PRIVATE_KEY.
# LICENSE_PRIVATE_KEY=

# ---- sign-in code emails ----
# DRIFTLY_MAILER options:
#   php-mail  → free + self-contained: sends as MAIL_FROM_EMAIL through the host's MTA
#               (PHP mail()). Enable DKIM for the domain in the panel and keep the host
#               IP in SPF so codes don't land in spam. This is our default.
#   console   → dev only; returns the code in the API response (no real email).
DRIFTLY_MAILER=php-mail
MAIL_FROM_EMAIL=support@driftly.site
MAIL_FROM_NAME=Driftly

# ---- payments (T-Bank / Т-Касса) ----
DRIFTLY_PROVIDER=tbank
TBANK_TERMINAL_KEY=YOUR_TERMINAL_KEY
TBANK_PASSWORD=YOUR_TERMINAL_PASSWORD
# AddCard verification for the free trial: HOLD = charge ~1 ₽ and return it (asks card number+exp+cvv),
# 3DSHOLD = the same + 3-D Secure (most secure, recommended for prod), 3DS = 0₽/3DS check, NO = save without check.
# The trial activates only AFTER this verification succeeds (RebillId captured via webhook).
TBANK_CHECKTYPE=HOLD
# TBANK_API=https://securepay.tinkoff.ru/v2
TBANK_NOTIFICATION_URL=https://api.driftly.site/v1/webhooks/tbank
TBANK_SUCCESS_URL=https://driftly.site/app/?paid=1
TBANK_FAIL_URL=https://driftly.site/app/?paid=0
# 54-ФЗ fiscal receipt (Init → Receipt). Set to match the ИП's real tax regime.
# TBANK_TAXATION: osn | usn_income | usn_income_outcome | patent | envd | esn  (default usn_income)
# TBANK_VAT: none | vat0 | vat5 | vat7 | vat10 | vat20 | vat110 | vat120       (default none)
TBANK_TAXATION=usn_income
TBANK_VAT=none

# ---- T-Bank certification (TEMPORARY) ----
# Set to a secret string to enable GET /v1/test/pay?t=<secret>&amount=<kopecks>, which opens a
# real payment form so T-Bank's 3 certification test cards can run (success/fail/refund).
# REMOVE this line once the merchant is switched to real data — it disables the endpoint (404).
# DRIFTLY_TEST_PAY=change-me-secret

# ---- misc ----
MAX_DEVICES=2
