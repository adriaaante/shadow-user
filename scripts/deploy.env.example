# Copy this file to scripts/deploy.env and fill in your REG.ru hosting details.
# scripts/deploy.env is gitignored — it stays only on your machine.
#
# Where to find these: REG.ru control panel -> your hosting -> "Доступ по FTP/SSH"
# (or the welcome email). The web root for an attached domain is usually
#   /home/<login>/<domain>/public_html  (ISPmanager-based plans).

DEPLOY_METHOD=ssh                 # ssh (rsync, preferred) or ftp (lftp)
DEPLOY_HOST=serverNNN.hosting.reg.ru
DEPLOY_USER=uNNNNNNN
DEPLOY_PATH=/home/uNNNNNNN/driftly.site/public_html
DEPLOY_PORT=22

# Only needed when DEPLOY_METHOD=ftp:
# DEPLOY_PASS=your_ftp_password
